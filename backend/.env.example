# YouTube Credentials
YT_CLIENT_ID=your_id_here
YT_CLIENT_SECRET=your_secret_here
YT_REDIRECT_URI=http://localhost:3000
YT_REFRESH_TOKEN=your_refresh_token_here

# Cloudflare Credentials
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_token_here
D1_DATABASE_ID=your_d1_database_id_here

# Server runtime
PORT=5000
# Cloudflare Worker origin allowed to call this backend (locks CORS). Required in prod.
ALLOWED_ORIGIN=https://shinel-auth.shinelstudioofficial.workers.dev
# Must match the CAPTIONS_SHARED_SECRET set in the Worker (wrangler secret).
# The Worker attaches this as X-Shinel-Captions-Secret; backend rejects mismatches.
CAPTIONS_SHARED_SECRET=generate_a_long_random_string_here
